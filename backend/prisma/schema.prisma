generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Station {
  id              String   @id @default(uuid())
  stationuuid     String   @unique
  name            String
  url             String
  urlResolved     String
  homepage        String?
  favicon         String?
  tags            String?
  country         String?
  countryCode     String?
  state           String?
  language        String?
  votes           Int      @default(0)
  codec           String?
  bitrate         Int?
  hls             Boolean  @default(false)
  lastCheckOk     Boolean  @default(true)
  geoLat          Float?
  geoLong         Float?
  clickCount      Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([geoLat, geoLong])
  @@index([country])
  @@index([language])
}
